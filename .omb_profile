# ~/.omb_profile

# Path to your oh-my-bash installation
export OSH="$HOME/.local/share/".oh-my-bash

# Set the theme for the prompt
OSH_THEME="agnoster"

# Completions to load
completions=(git composer ssh)

# Aliases to load
aliases=(general)

# Plugins to load
plugins=(git bashmarks)

# Allow oh-my-bash to use sudo
OMB_USE_SUDO=true

# Updates
DISABLE_AUTO_UPDATE="true"

# Load oh-my-bash framework
source "$OSH"/oh-my-bash.sh
